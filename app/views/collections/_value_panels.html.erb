<div class="row menu">
  <% @collections.each do |feature| %>
    <div class="col-md-5 tile">
      <div class="logo">
        <%= link_to feature.url, target: "_blank", rel: "noopener noreferrer", style: "text-decoration:none;" do -%>
          <% img_url = feature.image_url %>
          <%# If the thumbnail is not external or in /public/feature-logos, we use the default thumbnail which is in the vite asset pipeline %>
          <% img_src = img_url.start_with?('http', '/feature-logos/') ? img_url : vite_asset_path("images/#{img_url}") %>
          <%= image_tag(img_src, alt: "link to #{feature.label} site") %>
        <%- end %>
      </div>
      <h3><%= feature.label %></h3>
      <p><%= feature.description %></p>
      <p><%= link_to("See all #{feature.label} content (#{feature.count} items)", featured_search_url(feature.value), class: "more-results") %></p>
    </div>
  <% end %>
</div>
