<div class="row menu">
  <% @collections.each do |feature| %>
    <div class="col-md-5 tile">
      <div class="logo">
        <%= link_to feature.url, target: "_blank", rel: "noopener noreferrer", style: "text-decoration:none;" do -%>
        <%#  TODO fix image tag %>
          <%# <%= image_tag(image_url(feature.image_url), alt: "link to #{feature.label} site") %> 
             <%= image_tag(image_url(feature.image_url), alt: "link to #{feature.label} site -- feature.image_url: #{feature.image_url} -- image_url(that): #{image_url(feature.image_url)}") %>
        <%- end %>
      </div>
      <h3><%= feature.label %></h3>
      <p><%= feature.description %></p>
      <p><%= link_to("See all #{feature.label} content (#{feature.count} items)", featured_search_url(feature.value), class: "more-results") %></p>
    </div>
  <% end %>
</div>
